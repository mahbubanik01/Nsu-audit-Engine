# ============================================================
# NSU Audit Engine - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# Or set these as system environment variables.
#
# On Windows (PowerShell):
#   $env:NSU_SMTP_SENDER = "your.email@gmail.com"
#
# On Linux/macOS:
#   export NSU_SMTP_SENDER="your.email@gmail.com"
# ============================================================

# ─── SMTP (Email OTP Delivery) ──────────────────────────────
# Required for sending OTP codes via email.
# Without these, OTP codes print to console (dev mode).
NSU_SMTP_HOST=smtp.gmail.com
NSU_SMTP_PORT=587
NSU_SMTP_SENDER=your.email@gmail.com
NSU_SMTP_PASSWORD=your_app_password_here

# ─── JWT (Authentication Tokens) ────────────────────────────
# If not set, a secret is auto-generated and saved to:
#   data/.jwt_secret
# You can set your own for consistency across deployments:
NSU_JWT_SECRET=
NSU_JWT_EXPIRY_HOURS=24

# ─── OTP Settings ───────────────────────────────────────────
NSU_OTP_EXPIRY_SECONDS=300
