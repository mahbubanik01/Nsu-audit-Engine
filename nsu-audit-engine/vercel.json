{
  "builds": [
    { "src": "src/api/main.py", "use": "@vercel/python" },
    { "src": "webapp/package.json", "use": "@vercel/static-build", "config": { "distDir": "dist" } }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "src/api/main.py" },
    { "src": "/(.*)", "dest": "webapp/$1" }
  ]
}
